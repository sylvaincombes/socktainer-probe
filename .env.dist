# socktainer-check configuration
# Copy this file to .env and fill in your paths.
# .env is gitignored — never commit it.
# Existing shell exports and CI environment variables always take precedence.

# Path to the Socktainer binary to test against.
# Defaults to auto-detection in .build/release/, .build/debug/, then PATH.
# Use the RELEASE binary to avoid the debug-only NIO assert crash.
SOCKTAINER_BINARY=../socktainer/.build/release/socktainer

# Path to the Docker CLI binary (default: auto-detected from PATH).
# DOCKER_BINARY=/opt/homebrew/bin/docker

# Docker context to use as a reference runtime for parity checks (default: colima).
# REFERENCE_CONTEXT=colima
